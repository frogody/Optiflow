{
  "name": "flow-orchestrator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "mcp:servers": "ts-node src/services/mcp/server/startServers.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run mcp:servers\"",
    "build:standalone": "next build",
    "docker:build": "docker build -t optiflow:latest .",
    "docker:start": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "deploy": "sh deploy.sh",
    "check-env": "node scripts/check-env.js",
    "generate-secret": "node scripts/generate-secret.js",
    "vercel-build": "prisma generate && next build",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/core": "0.34.2",
    "@auth/prisma-adapter": "^2.8.0",
    "@headlessui/react": "^2.2.1",
    "@heroicons/react": "^2.2.0",
    "@pipedream/sdk": "^1.5.1",
    "@prisma/client": "^5.10.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/js-cookie": "^3.0.6",
    "axios": "^1.6.7",
    "bcryptjs": "^3.0.2",
    "express": "^4.18.2",
    "framer-motion": "^12.7.2",
    "googleapis": "^148.0.0",
    "js-cookie": "^3.0.5",
    "next": "^14.1.0",
    "next-auth": "^4.24.11",
    "openai": "^4.28.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.5.2",
    "react-icons": "^5.5.0",
    "reactflow": "^11.10.1",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "zod": "^3.22.4",
    "zustand": "^4.5.0"
