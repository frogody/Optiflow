# Next.js Environment
NODE_ENV=production
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# Pipedream Configuration
PIPEDREAM_CLIENT_ID=your_pipedream_client_id
PIPEDREAM_CLIENT_SECRET=your_pipedream_client_secret
PIPEDREAM_PROJECT_ID=your_pipedream_project_id
PIPEDREAM_ENVIRONMENT=production

# External API Keys
OPENAI_API_KEY=your_openai_api_key
CLAY_API_KEY=your_clay_api_key
HUBSPOT_API_KEY=your_hubspot_api_key

# Database Connection
DATABASE_URL=postgresql://username:password@localhost:5432/dbname

# Session Security
JWT_SECRET=your_jwt_secret_key
COOKIE_SECRET=your_cookie_secret_key

# Service Endpoints
MCP_SERVICE_URL=https://mcp.yourdomain.com
ANALYTICS_SERVICE_URL=https://analytics.yourdomain.com

# Pipedream Connect Configuration
NEXT_PUBLIC_PIPEDREAM_CLIENT_ID=your_pipedream_client_id
PIPEDREAM_PROJECT_ENVIRONMENT=production

# App URLs
NEXT_PUBLIC_APP_URL=https://your-app-url.vercel.app
NEXT_PUBLIC_PIPEDREAM_REDIRECT_URI=https://your-app-url.vercel.app/api/pipedream/callback 