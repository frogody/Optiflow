# Next.js Environment
NODE_ENV=development
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# Authentication
AUTH_SECRET=your-auth-secret
SESSION_MAX_AGE=2592000 # 30 days in seconds

# Database Connection
DATABASE_URL="file:./dev.db"

# Session Security
ENCRYPTION_KEY=your-32-char-encryption-key
JWT_SECRET=your-jwt-secret

# Pipedream Connect Configuration
NEXT_PUBLIC_PIPEDREAM_CLIENT_ID=your-pipedream-client-id
PIPEDREAM_CLIENT_SECRET=your-pipedream-client-secret
NEXT_PUBLIC_PIPEDREAM_PROJECT_ID=your-pipedream-project-id
NEXT_PUBLIC_PIPEDREAM_TOKEN=your-pipedream-token
NEXT_PUBLIC_PIPEDREAM_FRONTEND_HOST=pipedream.com

# App URLs
NEXT_PUBLIC_APP_URL=https://your-app-url.vercel.app
NEXT_PUBLIC_PIPEDREAM_REDIRECT_URI=https://your-app-url.vercel.app/api/oauth/callback

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# External API Keys
OPENAI_API_KEY=your_openai_api_key
CLAY_API_KEY=your_clay_api_key
HUBSPOT_API_KEY=your_hubspot_api_key

# Service Endpoints
MCP_SERVICE_URL=https://mcp.yourdomain.com
ANALYTICS_SERVICE_URL=https://analytics.yourdomain.com

# Pipedream Configuration
PIPEDREAM_PROJECT_ID=your_pipedream_project_id
PIPEDREAM_ENVIRONMENT=production
PIPEDREAM_PROJECT_ENVIRONMENT=production 